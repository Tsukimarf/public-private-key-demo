{
  "comment": "Public/Private Key Demo — Complete JSON Data Structures",

  "schemas": {
    "keyPair": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "KeyPair",
      "type": "object",
      "required": ["privateKey", "publicKey", "curve", "createdAt"],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid",
          "description": "Unique record identifier"
        },
        "label": {
          "type": "string",
          "description": "Human-readable name for this key"
        },
        "privateKey": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$",
          "description": "256-bit private key in hex — KEEP SECRET"
        },
        "publicKey": {
          "type": "string",
          "pattern": "^04[0-9a-f]{128}$",
          "description": "Uncompressed secp256k1 public key (04 prefix + x + y)"
        },
        "curve": {
          "type": "string",
          "enum": ["secp256k1", "p-256", "p-384", "ed25519"],
          "default": "secp256k1"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },

    "signature": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ECDSASignature",
      "type": "object",
      "required": ["algorithm", "r", "s"],
      "properties": {
        "algorithm": {
          "type": "string",
          "enum": ["ECDSA-secp256k1", "ECDSA-p256", "EdDSA-ed25519"]
        },
        "r": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$",
          "description": "Signature r component (32 bytes hex)"
        },
        "s": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$",
          "description": "Signature s component (32 bytes hex)"
        },
        "v": {
          "type": "integer",
          "enum": [27, 28],
          "description": "Recovery id (Ethereum-compatible)"
        },
        "der": {
          "type": "string",
          "description": "DER-encoded signature (hex)"
        }
      }
    },

    "signedTransaction": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "SignedTransaction",
      "type": "object",
      "required": ["transaction", "hash", "signature", "publicKey"],
      "properties": {
        "transaction": {
          "type": "object",
          "required": ["from", "to", "amount", "timestamp"],
          "properties": {
            "id":        { "type": "string" },
            "from":      { "type": "string", "description": "Sender public key or address" },
            "to":        { "type": "string", "description": "Recipient address" },
            "amount":    { "type": "number", "minimum": 0 },
            "currency":  { "type": "string" },
            "timestamp": { "type": "string", "format": "date-time" },
            "memo":      { "type": "string" }
          }
        },
        "hash": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$",
          "description": "SHA-256 of the serialized transaction"
        },
        "signature": { "$ref": "#/schemas/signature" },
        "publicKey":  { "type": "string" },
        "verified":   { "type": "boolean" }
      }
    },

    "keyDatabase": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "KeyDatabase",
      "type": "object",
      "properties": {
        "version": { "type": "integer", "enum": [1] },
        "keys": {
          "type": "array",
          "items": { "$ref": "#/schemas/keyPair" }
        }
      }
    }
  },

